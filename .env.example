# Base directories — the track slug is appended as a subdirectory at runtime.
# e.g. STEMS_DIR/first-principles/1.mp3, OUTPUT_DIR/first-principles/output-*.mp3
STEMS_DIR=/path/to/stems-base
OUTPUT_DIR=/path/to/output-base

# SQLite database path (default: de.db in the working directory)
# DB_PATH=de.db

# Production R2 — leave unset locally; presence of R2_STEMS_BUCKET switches
# get_stems() from local filesystem paths to R2 presigned URLs.
# R2_ACCESS_KEY_ID and R2_SECRET_ACCESS_KEY are R2 S3-compatible credentials
# (Cloudflare dashboard → R2 → Manage R2 API tokens), NOT the Cloudflare API token.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_STEMS_BUCKET=
