# /etc/difference-engine/env
# chmod 600 /etc/difference-engine/env
# chown root:root /etc/difference-engine/env
#
# This file is the production EnvironmentFile for the systemd service.
# Do not commit the actual env file — only this example.

PORT=8000
DB_PATH=/var/lib/difference-engine/de.db
STEMS_DIR=/path/to/stems-base
OUTPUT_DIR=/var/lib/difference-engine/output

# R2 — leave unset to use local filesystem stems
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_STEMS_BUCKET=
